{
  "name": "lidlgroovy",
  "version": "1.0.0",
  "description": "lidlgroovy discord bot",
  "license": "ISC",
  "author": "Zwoooz",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:deploy": "npx tsx src/deployCommands.ts",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" npx jest",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "deploy": "node dist/deployCommands.js",
    "start": "node .",
    "lint": "npx eslint --max-warnings 0",
    "lint:fix": "npx eslint --fix",
    "lint:fix-dry": "npx eslint --fix-dry-run",
    "format": "npx prettier --write src/**/*.ts",
    "format:check": "npx prettier --check src/**/*.ts",
    "setup": "bash scripts/setup-hooks.sh",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/add": "^6.0.1",
    "@graphql-codegen/cli": "6.3.1",
    "@graphql-codegen/typed-document-node": "^6.1.8",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "@graphql-codegen/typescript-resolvers": "5.1.8",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jest": "^30.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "swagger-typescript-api": "^13.6.5",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "@discord-player/extractor": "^7.2.0",
    "@discordjs/voice": "^0.19.2",
    "canvas": "^3.2.3",
    "chalk": "^5.6.2",
    "discord-player": "^7.2.0",
    "discord-player-youtube": "^0.8.4",
    "discord-player-youtubei": "^1.5.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "graphql": "^16.13.2",
    "libsodium-wrappers": "^0.8.2",
    "rimraf": "^6.1.3"
  }
}
